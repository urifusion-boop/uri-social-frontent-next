# Environment Variables Example
# Copy this file to .env.local and update with your values

# Backend API URL
# Local Development: http://localhost:9003
# Staging (VM with HTTPS): https://20.164.0.168/social-media
# Production: https://api.uricreative.com
NEXT_PUBLIC_URI_API_BASE_URL=http://localhost:9003

# Google OAuth (for Sign in / Sign up with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include: http://localhost:3000/login
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
