{
  "routes": [],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif,ico}", "/*.{css,js}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "content-security-policy": "default-src 'self' https: 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https://api.urisocial.com https://api-staging.urisocial.com"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
